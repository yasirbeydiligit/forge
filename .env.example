# ──────────────────────────────────────────────────────────────────────────
#  Supabase — public client configuration (safe to expose to the browser)
# ──────────────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Use the "publishable" key (sb_publishable_...) or the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx_or_legacy_anon_jwt"

# Absolute base URL of this deployment. Used to build shareable invite links.
# Local dev: http://localhost:3000 — Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────
#  Supabase — server-only secret (NEVER expose to the browser)
# ──────────────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API Keys → service_role (secret).
# Required for: invite sign-up (admin user creation) and the seed script.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ──────────────────────────────────────────────────────────────────────────
#  Postgres connection — only needed for the Drizzle CLI (db:migrate / db:push)
# ──────────────────────────────────────────────────────────────────────────
# Dashboard → Connect → ORMs / "Connection string". Use the session pooler.
# Example: postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────────────────────────────────
#  Seed script — first coach account (change after first login)
# ──────────────────────────────────────────────────────────────────────────
SEED_COACH_EMAIL="coach@example.com"
SEED_COACH_PASSWORD="change-me-please"
SEED_COACH_NAME="Koç"

# ──────────────────────────────────────────────────────────────────────────
#  Research Library RAG — server-only secrets (NEVER expose to the browser)
# ──────────────────────────────────────────────────────────────────────────
# Voyage AI — used for embeddings. Get a key at https://www.voyageai.com
VOYAGE_AI_API_KEY="your-voyage-ai-api-key"
# Anthropic — used for chat/generation. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key"
